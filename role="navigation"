<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Navigation role demo</title>  
  </head>
  <body>
    <h1>Role navigation Example</h1>
    <div role="navigation">
      <a href="#home">Home</a>|
      <a href="#about">About</a>|
      <a href="#contact">Contact</a>
    </div>
    <section id="home">
      <h2>Home</h2>
      <p>This is the home section.</p>
    </section>
    <section id="about">
      <h2>About</h2>
      <p>This is the about section.</p>
    </section>
    <section id="contact">
      <h2>Contact</h2>
      <p>This is the contact section.</p>
    </section>
  </body>    
</html>
