<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="description" content="HTML Master Exploration">
  <meta name="keywords" content="HTML,learning, exploration">
  <meta name="author" content="you">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>HTML Master Exploration</title>
  <style>
    body {
      font-family: Arial;
      margin: 20px;
    }
    .box {
      border: 2px solid black;
      padding: 10px;
      margin: 10px 0;
    }
    .flex {
      display: flex;
      gap: 10px;
    }
  </style>
</head>
<body>
  <h1>Main Heading</h1>
  <h2>Sub Heading</h2>
  <h3>Smaller Heading</h3>
  <p>This is a <b>bold</b>,<i>italic</i>,<u>underlined</u> paragraph.</p>
  <p>19<sup>2</sup></p>
  <p>H<sub>2</sub>O</p>
  <hr>
  <h2>Links</h2>
  <a href="https://www.google.com" target="_blank">
  Open Google</a>
  <h2>Images</h2>
  <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/2/2f/Google_2015_logo.svg/500px-Google_2015_logo.svg.png" alt="placehoder image">
  <h2>Lists</h2>
  <h3>Unordered List</h3>
  <ul>
    <li>Apple</li>
    <li>Banana</li>
  </ul>  
  <ol>
    <li>step 1</li>
    <li>step 2</li>
  </ol>  
  <h3>Definition List</h3>
    <dl>
      <dt>HTML</dt>
      <dd>structure of webpages</dd>
    </dl>
  <h2>Tables</h2>  
  <table border="1">
    <tr>
      <th>Name</th>
      <th>Age</th>
    </tr>
    <tr>
      <td>alice</td>
      <td>25</td>
    </tr>
  </table>
  <h2>Div & span</h2>
  <div class="box">I AM A DIV (BLOCK ELEMENT)</div>
  <span class="box">I AM A SPAN (INLINE ELEMENT)</span>
</body>
</html>    
